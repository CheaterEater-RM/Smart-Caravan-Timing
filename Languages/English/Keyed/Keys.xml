<LanguageData>
    <!-- ── Arrival mode gizmo labels ── -->
    <SCT_Mode_Normal>Normal</SCT_Mode_Normal>
    <SCT_Mode_Normal_Desc>Vanilla caravan behavior. The caravan rests and travels as usual.</SCT_Mode_Normal_Desc>
    <SCT_Mode_PushOn>Push On</SCT_Mode_PushOn>
    <SCT_Mode_PushOn_Desc>When within {0} hours of the destination, skip rest stops and push straight through.</SCT_Mode_PushOn_Desc>
    <SCT_Mode_ArriveReady>Arrive Ready</SCT_Mode_ArriveReady>
    <SCT_Mode_ArriveReady_Desc>Pause before arrival to fulfill needs. Pawns will sleep, eat, and recreate before proceeding.</SCT_Mode_ArriveReady_Desc>

    <!-- ── Rest schedule gizmo labels ── -->
    <SCT_RestMode_Normal>Rest: Normal</SCT_RestMode_Normal>
    <SCT_RestMode_Normal_Desc>Caravan rests according to the configured rest window.</SCT_RestMode_Normal_Desc>
    <SCT_RestMode_Altered>Rest: Custom Schedule</SCT_RestMode_Altered>
    <SCT_RestMode_Altered_Desc>Caravan rests during the custom window ({0}–{1}) instead of the default window.</SCT_RestMode_Altered_Desc>
    <SCT_RestMode_NoResting>Rest: No Resting</SCT_RestMode_NoResting>
    <SCT_RestMode_NoResting_Desc>Caravan never stops automatically to rest. Pawns will grow tired but keep moving. You can still order a manual rest stop.</SCT_RestMode_NoResting_Desc>

